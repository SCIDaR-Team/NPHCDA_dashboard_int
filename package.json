{
  "name": "nphcda-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "NPHCDA PHC Readiness, Stock & Service Dashboard — an enterprise analytics platform for Primary Health Care performance across Nigeria.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "data:refresh": "node etl/build.mjs",
