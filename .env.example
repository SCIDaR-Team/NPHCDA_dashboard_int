# Which data source the app uses:
#   mock     (default) → preserved illustrative figures
#   snapshot           → real data from the ETL snapshot (run `npm run data:refresh`)
#   api                → live backend via ApiDataSource
VITE_DATA_SOURCE=mock

# Base URL for the live backend (only used when VITE_DATA_SOURCE=api)
VITE_API_BASE_URL=/api

# Simulated latency for the mock data source, in ms (set 0 to disable loading states)
VITE_MOCK_LATENCY_MS=350
