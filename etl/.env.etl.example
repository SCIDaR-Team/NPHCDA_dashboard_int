# Credentials for the ETL (npm run data:refresh). Copy this file to
# etl/.env.etl (git-ignored) and fill in real values. These are used ONLY by the
# Node ETL script and are never bundled into the browser app.

# SRH ODK (project 1239 — SRH Routine tool)
SRH_ODK_USER=
SRH_ODK_PASS=

# SFM ODK (project 381 — HSDF consortium facility monitoring tool)
SFM_ODK_USER=
SFM_ODK_PASS=

# SRH Google Sheet — public published-CSV export (NO auth; this is config, not a
# secret). Optional: leave blank to use the built-in baseline URL; set only to
# point the ETL at a re-published sheet.
SRH_SHEET_URL=

# PFMO Data Export API — sent in the X-API-Key header (key shape: pfmo_<prefix>_<secret>).
# Endpoint: https://api.app.pfmo.ng/api/v1/external/export/monthly?month&year
PFMO_API_KEY=
